# ─────────────────────────────────────────────────────
# AI Business Analyzer — Environment Variables
# ─────────────────────────────────────────────────────
# 1. Copy this file and rename it to   .env
# 2. Fill in your HuggingFace API token below
# 3. Get a FREE token at: https://huggingface.co/settings/tokens

HF_API_TOKEN=your_huggingface_token_here

# ─────────────────────────────────────────────────────
# HOW TO GET YOUR FREE TOKEN (takes 2 minutes):
# 1. Go to  https://huggingface.co  and sign up (free)
# 2. Click your profile → Settings → Access Tokens
# 3. Click "New token" → give it any name → Role: Read
# 4. Copy the token and paste it above
# ─────────────────────────────────────────────────────
